{
  "name": "mochawesome",
  "version": "8.0.0-alpha.0",
  "description": "A gorgeous reporter for Mocha.js (v8 alpha)",
  "private": true,
  "main": "./dist/reporter/mocha.js",
  "exports": {
    ".": "./dist/reporter/mocha.js",
    "./register": "./register.cjs"
  },
  "files": [
    "dist",
    "register.cjs",
    "!dist/**/*.map"
  ],
  "scripts": {
    "check": "npm run typecheck && npm run lint && npm run format:check",
    "build": "npm run check && tsc -p tsconfig.build.json",
    "prepack": "npm run build",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint .",
    "format": "prettier . --write",
    "format:check": "prettier . --check"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.0.3",
    "@vitest/eslint-plugin": "^1.6.4",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "mocha": "^8.3.0",
    "prettier": "^3.4.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.18.0",
    "vitest": "^4.0.16"
  }
}
