{
  "name": "mochawesome-renderer",
  "version": "8.0.0-alpha.0",
  "description": "Mochawesome v8 HTML renderer",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "files": [
    "dist",
    "!dist/**/*.map"
  ],
  "scripts": {
    "check": "npm run typecheck && npm run test",
    "build": "tsc -p tsconfig.build.json",
    "dev": "vite",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "@types/node": "^25.0.3",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "typescript": "^5.9.3",
    "vite": "^6.0.11",
    "vitest": "^4.0.16"
  }
}
